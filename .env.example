# Domínio base da VPS (ex: cliente.com)
# API dos projetos: api.<nome>.<DOMAIN_BASE>
DOMAIN_BASE=

# Postgres
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD=

# Redis
REDIS_PASSWORD=

# Backup
BACKUP_DIR=/var/backups/infra
BACKUP_RETENTION_DAYS=60

# Notificações via Telegram (deixe vazio para desativar)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SILENT=true
RESOURCES_TELEGRAM_ENABLED=true
BACKUP_TELEGRAM_ENABLED=true

# Alertas de recursos (porcentagem)
RESOURCE_DISK_THRESHOLD=80
RESOURCE_RAM_THRESHOLD=85
RESOURCE_CPU_THRESHOLD=90

# Google Drive (rclone) — deixe vazio para desativar upload
RCLONE_REMOTE=
RCLONE_PATH=infra/backups
